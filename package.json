{
  "name": "gemini-antigravity-rce",
  "version": "1.0.0",
  "description": "High-performance RCE backend using Node.js, Express, Supabase and Dockerode",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.6",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  }
}
